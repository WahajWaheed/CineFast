<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/home_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_logo"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp">

        </ImageView>

        <!-- Movie 1 -->
        <LinearLayout
            android:id="@+id/movie1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="@android:drawable/list_selector_background">

            <ImageView
                android:id="@+id/poster1"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:src="@drawable/poster_movie1"
                android:scaleType="centerCrop"
                android:contentDescription="Movie Poster"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingLeft="8dp">

                <TextView
                    android:id="@+id/movie_name1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/movie1_name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/movie_genre1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/movie1_genre"
                    android:textSize="14sp"
                    android:textColor="@color/movie_genre"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <ImageButton
                        android:id="@+id/btn_trailer1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_youtube"
                        android:layout_marginEnd="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/trailer"/>

                    <Button
                        android:id="@+id/btn_book1"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/book_seats"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/red"
                        style="@style/Widget.CineFAST.Button"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Movie 2 -->
        <LinearLayout
            android:id="@+id/movie2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="@android:drawable/list_selector_background">

            <ImageView
                android:id="@+id/poster2"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:src="@drawable/poster_movie2"
                android:scaleType="centerCrop"
                android:contentDescription="Movie Poster"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingLeft="8dp">

                <TextView
                    android:id="@+id/movie_name2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/movie2_name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/movie_genre2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/movie2_genre"
                    android:textSize="14sp"
                    android:textColor="@color/movie_genre"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <ImageButton
                        android:id="@+id/btn_trailer2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_youtube"
                        android:layout_marginEnd="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/trailer"/>

                    <Button
                        android:id="@+id/btn_book2"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/book_seats"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/red"
                        style="@style/Widget.CineFAST.Button"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Movie 3 -->
        <LinearLayout
            android:id="@+id/movie3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="@android:drawable/list_selector_background">

            <ImageView
                android:id="@+id/poster3"
                android:layout_width="80dp"
                android:layout_height="120dp"
                android:src="@drawable/poster_movie3"
                android:scaleType="centerCrop"
                android:contentDescription="Movie Poster"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingLeft="8dp">

                <TextView
                    android:id="@+id/movie_name3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/movie3_name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/movie_genre3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/movie3_genre"
                    android:textSize="14sp"
                    android:textColor="@color/movie_genre"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <ImageButton
                        android:id="@+id/btn_trailer3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_youtube"
                        android:layout_marginEnd="10dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/trailer"/>

                    <Button
                        android:id="@+id/btn_book3"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/book_seats"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/red"
                        style="@style/Widget.CineFAST.Button"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>