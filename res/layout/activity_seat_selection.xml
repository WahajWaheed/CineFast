<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Movie Title -->
        <TextView
            android:id="@+id/tv_movie_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oppenheimer"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Rating, Language, Screen -->
        <TextView
            android:id="@+id/tv_movie_rating_lang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+13  EN"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_movie_screen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ScreenX"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"/>

        <!-- Theater, Hall, Date, Time in a grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theater"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_column="0"
                android:layout_row="0"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tv_theater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stars (90°Mall)"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_column="1"
                android:layout_row="0"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hall"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_column="0"
                android:layout_row="1"/>

            <TextView
                android:id="@+id/tv_hall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1st"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_column="1"
                android:layout_row="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_column="0"
                android:layout_row="2"/>

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13.04.2025"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_column="1"
                android:layout_row="2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_column="0"
                android:layout_row="3"/>

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22:15"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_column="1"
                android:layout_row="3"/>
        </GridLayout>

        <!-- Legend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginEnd="24dp">
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@color/seat_booked"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booked"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginEnd="24dp">
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@color/seat_selected"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yours"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@color/seat_available"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Seat Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Seats"
            android:textSize="18sp"
            android:textColor="@color/select_seats"
            android:layout_marginBottom="8dp"/>

        <GridLayout
            android:id="@+id/seat_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="5"
            android:rowCount="5"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="true"
            android:padding="8dp"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center"/>

        <!-- Total selected seats -->
        <TextView
            android:id="@+id/tv_total_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/selected_seats_0"
            android:textSize="16sp"
            android:textColor="@color/selected_seats"
            android:layout_marginBottom="16dp"/>

        <!-- Buttons (Book Seats left, Proceed right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_book_seats"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Book Seats"
                android:backgroundTint="@color/red"
                android:layout_marginEnd="8dp"
                style="@style/Widget.CineFAST.Button"/>

            <Button
                android:id="@+id/btn_proceed_snacks"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Proceed to Snacks"
                android:enabled="false"
                android:layout_marginStart="8dp"
                android:layout_gravity="center"
                style="@style/Widget.CineFAST.Button"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
